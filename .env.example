# Supabase, Settings > API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://wjpmdwugnwuydomdmetf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Stripe, Developers > API Keys in your Stripe dashboard
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs, create these in your Stripe dashboard.
# One-off guide prices live in the products table (products.stripe_price_id),
# set via supabase/stripe-prices.sql, not here.
STRIPE_PRICE_PREMIUM_ANNUAL=price_...     # £49.99/year

# Site
NEXT_PUBLIC_SITE_URL=https://jaxfamilytravels.com

# WayStaq <-> JFT discount bridge. Shared HMAC secret, must hold the SAME
# value as WayStaq's JFT_BRIDGE_SECRET. Signs the outbound token in
# /api/waystaq/upgrade-link and verifies the inbound token in
# /api/from-waystaq. In production this is a Worker secret, not committed:
#   npx wrangler secret put WAYSTAQ_BRIDGE_SECRET
WAYSTAQ_BRIDGE_SECRET=change-me-to-a-long-random-string
# The discounted £25/yr JFT Premium price ID. When a valid WayStaq discount
# cookie is present, /api/stripe/subscribe swaps STRIPE_PRICE_PREMIUM_ANNUAL
# for this price so the logged-in checkout (and its Premium-granting
# webhook) runs at £25 instead of £49.99.
WAYSTAQ_DISCOUNT_PRICE_ID=price_...
# Comma-separated allowlist of admin / comped WayStaq accounts that are
# premium WITHOUT a real Stripe subscription. These skip JFT's Stripe
# re-check in /api/from-waystaq (the HMAC token is still verified). Keep it
# tiny and limited to accounts you control. Leave empty to disable.
WAYSTAQ_BRIDGE_BYPASS_EMAILS=

# Resend, for outgoing transactional emails (call request confirmations,
# welcome emails). Get key from resend.com > API Keys. In production this
# is set as a Cloudflare Worker secret, not committed:
#   npx wrangler secret put RESEND_API_KEY
RESEND_API_KEY=re_xxx

# Unsubscribe token signing, any long random string. HMAC-SHA256 signs
# the one-click unsubscribe URLs embedded in future marketing emails.
# In production this is a Worker secret. Generate with:
#   openssl rand -base64 48
#   npx wrangler secret put UNSUBSCRIBE_SIGNING_SECRET
UNSUBSCRIBE_SIGNING_SECRET=change-me-to-a-long-random-string
