# env
# .env.production IS committed — public NEXT_PUBLIC_* values needed by
# the Cloudflare auto-build. Anything secret stays in Worker secrets.
.env
.env.local
.env.*.local
!.env.production

# Source PDFs and any related working files (compressed zips, etc.)
# kept locally, uploaded to Supabase Storage — don't bloat git
/guides/
!/guides/.gitkeep

