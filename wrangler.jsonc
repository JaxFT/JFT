{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "jaxfamilytravels",
  "compatibility_date": "2026-05-16",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  // Explicit CPU ceiling per request on Workers Paid. Default budget
  // is much tighter than the 30s plan max; making it explicit gives
  // image-heavy paths (guide rendering, downloads) all the headroom
  // they need without bumping into Error 1102.
  "limits": {
    "cpu_ms": 30000
  },
  // Plaintext env vars (non-secrets). Wrangler wipes any dashboard-set
  // plaintext vars on deploy and uses ONLY what's here, so add them
  // here, not in the dashboard. Secrets (sk_, whsec_, service role,
  // anthropic key) stay in the dashboard, wrangler preserves those.
  "vars": {
    "STRIPE_PRICE_PREMIUM_ANNUAL": "price_1TYcwmBedsajl023wYj7iJIJ",
    "STRIPE_PRICE_ADVENTURE_PACK": "price_1TZX3BBedsajl023ycbRWXcj",
    "STRIPE_PAYMENT_LINK_1_TO_1_CALL": "https://buy.stripe.com/28E7sK88Q6NKgfY4TB4Ja01",
    "WAYSTAQ_DISCOUNT_PRICE_ID": "price_1TbFy7Bedsajl0230KDigaww",
    "STRIPE_PRICE_ASIA_ADVENTURES_VIEW": "price_1TeCA6Bedsajl023LqhnxLQw",
    "WAYSTAQ_ASIA_ADVENTURES_URL": "https://waystaq.com/redeem?trip=asia-adventures",
    "NEXT_PUBLIC_SITE_URL": "https://jaxfamilytravels.com",
    "NEXT_PUBLIC_SUPABASE_URL": "https://wjpmdwugnwuydomdmetf.supabase.co",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6IndqcG1kd3Vnbnd1eWRvbWRtZXRmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzg5MDA5NTEsImV4cCI6MjA5NDQ3Njk1MX0.gzFMj1nzt2JmhnaYBnj54q-6n5G3TuwEqdxWBQkLOgk"
  }
}
